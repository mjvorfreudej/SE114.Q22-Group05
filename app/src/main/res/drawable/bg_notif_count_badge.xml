<?xml version="1.0" encoding="utf-8"?>
<!--
  Red unread-count badge on the dashboard bell (design RoleHeader: #FF4B4B fill,
  2px white border, fully rounded). Sits top-end over the bell button.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/adm_red_500" />
    <corners android:radius="999dp" />
    <stroke
        android:width="2dp"
        android:color="@color/white" />
</shape>
