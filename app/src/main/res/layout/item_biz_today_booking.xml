<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_adm_rounded_12"
    android:clickable="true"
    android:elevation="2dp"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <TextView
        android:id="@+id/bizTodayAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/bizTodayGuest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/adm_gray_900"
            android:textSize="12.5sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bizTodaySub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/adm_gray_500"
            android:textSize="10.5sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/bizTodayStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_adm_pill"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>
