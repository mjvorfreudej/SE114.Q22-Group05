<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adm_gray_100">

    <FrameLayout
        android:id="@+id/biz_fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bizBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Floating Bottom Navigation (matches the user app's pill style) -->
    <LinearLayout
        android:id="@+id/bizBottomNav"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:animateLayoutChanges="true"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/bizTabHome"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/bizIconHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/biz_nav_home"
                android:src="@drawable/ic_home_24"
                app:tint="@color/adm_gray_400" />

            <TextView
                android:id="@+id/bizLabelHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/biz_nav_home"
                android:textColor="@color/adm_gray_900"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Listings -->
        <LinearLayout
            android:id="@+id/bizTabListings"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/bizIconListings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/biz_nav_listings"
                android:src="@drawable/ic_building"
                app:tint="@color/adm_gray_400" />

            <TextView
                android:id="@+id/bizLabelListings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/biz_nav_listings"
                android:textColor="@color/adm_gray_900"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Calendar -->
        <LinearLayout
            android:id="@+id/bizTabCalendar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/bizIconCalendar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/biz_nav_calendar"
                android:src="@drawable/ic_calendar"
                app:tint="@color/adm_gray_400" />

            <TextView
                android:id="@+id/bizLabelCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/biz_nav_calendar"
                android:textColor="@color/adm_gray_900"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Reviews (with badge) -->
        <LinearLayout
            android:id="@+id/bizTabReviews"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/bizIconReviews"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/biz_nav_reviews"
                    android:src="@drawable/ic_star"
                    app:tint="@color/adm_gray_400" />

                <TextView
                    android:id="@+id/bizBadgeReviews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_adm_pill"
                    android:backgroundTint="@color/adm_red_500"
                    android:gravity="center"
                    android:minWidth="16dp"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="1dp"
                    android:text="8"
                    android:textColor="@color/white"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />
            </FrameLayout>

            <TextView
                android:id="@+id/bizLabelReviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/biz_nav_reviews"
                android:textColor="@color/adm_gray_900"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/bizTabProfile"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/bizIconProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/biz_nav_profile"
                android:src="@drawable/ic_person_24"
                app:tint="@color/adm_gray_400" />

            <TextView
                android:id="@+id/bizLabelProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/biz_nav_profile"
                android:textColor="@color/adm_gray_900"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
