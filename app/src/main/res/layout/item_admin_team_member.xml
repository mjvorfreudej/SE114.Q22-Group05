<?xml version="1.0" encoding="utf-8"?>
<!-- Admin team member row: initials avatar · name + email · role chip. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_adm_rounded_12"
    android:backgroundTint="@color/adm_gray_50"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/admMemberAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/admMemberName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/adm_gray_900"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/admMemberEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/adm_gray_500"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/admMemberRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_adm_pill"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textSize="10.5sp"
        android:textStyle="bold" />
</LinearLayout>
