<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_outline_gray_14"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingVertical="12dp">

    <FrameLayout
        android:id="@+id/bizQaIconWrap"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_adm_rounded_10">

        <ImageView
            android:id="@+id/bizQaIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:contentDescription="@null" />
    </FrameLayout>

    <TextView
        android:id="@+id/bizQaLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/adm_gray_900"
        android:textSize="11.5sp"
        android:textStyle="bold" />
</LinearLayout>
