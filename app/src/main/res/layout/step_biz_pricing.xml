<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView style="@style/BizStepHeading" android:text="@string/biz_s3_title" />
    <TextView style="@style/BizStepSub" android:text="@string/biz_s3_sub" />

    <!-- Base price -->
    <TextView
        android:id="@+id/bizPriceLabel"
        style="@style/BizFieldLabel"
        android:layout_marginTop="14dp"
        android:text="@string/biz_base_price_night" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_biz_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_dollar"
            app:tint="@color/adm_gray_400" />

        <EditText
            android:id="@+id/bizPrice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="199"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLines="1"
            android:textColor="@color/adm_gray_900"
            android:textColorHint="@color/adm_gray_400"
            android:textSize="13sp"
            tools:ignore="HardcodedText"
            xmlns:tools="http://schemas.android.com/tools" />
    </LinearLayout>

    <!-- Capacity limit -->
    <TextView
        android:id="@+id/bizCapacityLabel"
        style="@style/BizFieldLabel"
        android:layout_marginTop="14dp"
        android:text="Số lượng phòng tối đa" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_biz_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:id="@+id/bizCapacityIcon"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_home_24"
            app:tint="@color/adm_gray_400" />

        <EditText
            android:id="@+id/bizCapacityInput"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="5"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLines="1"
            android:textColor="@color/adm_gray_900"
            android:textColorHint="@color/adm_gray_400"
            android:textSize="13sp"
            xmlns:tools="http://schemas.android.com/tools" />
    </LinearLayout>

    <!-- Seasonal toggle card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_outline_gray_14"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_adm_rounded_8"
            android:backgroundTint="@color/adm_orange_50">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_percent"
                app:tint="@color/adm_amber_500" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/biz_seasonal"
                android:textColor="@color/adm_gray_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/biz_seasonal_sub"
                android:textColor="@color/adm_gray_500"
                android:textSize="11sp" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/bizSeasonalToggle"
            style="@style/AdmSwitch"
            android:checked="true" />
    </LinearLayout>

    <!-- Season rows -->
    <LinearLayout
        android:id="@+id/bizSeasonRows"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <include
            layout="@layout/item_biz_season_row"
            android:id="@+id/bizSeasonPeak" />

        <include
            layout="@layout/item_biz_season_row"
            android:id="@+id/bizSeasonMid" />

        <include
            layout="@layout/item_biz_season_row"
            android:id="@+id/bizSeasonOff" />
    </LinearLayout>

    <!-- Extra fees -->
    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="@string/biz_extra_fees" />

    <include layout="@layout/item_biz_fee_row" android:id="@+id/bizFeeCleaning" />

    <include layout="@layout/item_biz_fee_row" android:id="@+id/bizFeeLate" />

    <include layout="@layout/item_biz_fee_row" android:id="@+id/bizFeeExtra" />
</LinearLayout>
