<?xml version="1.0" encoding="utf-8"?>
<!-- Audit log entry: tinted action icon · action text · actor • time meta. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_adm_rounded_12"
    android:backgroundTint="@color/adm_gray_50"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/admAuditIconWrap"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="1dp"
        android:background="@drawable/bg_adm_rounded_8"
        android:backgroundTint="@color/adm_gray_100">

        <ImageView
            android:id="@+id/admAuditIcon"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_history"
            app:tint="@color/adm_gray_700" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/admAuditAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.3"
            android:textColor="@color/adm_gray_900"
            android:textSize="12.5sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/admAuditMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/adm_gray_400"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
