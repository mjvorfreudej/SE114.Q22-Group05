<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact notification row for the bell popover (design TravelerBell row):
  category disc · title + right-aligned timestamp · single-line body, with an
  unread blue dot and a hairline bottom divider. A condensed variant of
  item_notification.xml — no quick-action pills, body clamped to one line.
  Row background (unread tint) and title weight are set in code.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notifPopRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="11dp">

        <!-- Category icon disc -->
        <FrameLayout
            android:id="@+id/notifPopIconDisc"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_adm_rounded_12">

            <ImageView
                android:id="@+id/ivNotifPopIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:contentDescription="@null" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="11dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Title + timestamp -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvNotifPopTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/adm_gray_900"
                    android:textSize="13sp"
                    tools:text="Booking confirmed" />

                <TextView
                    android:id="@+id/tvNotifPopWhen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/adm_gray_400"
                    android:textSize="10.5sp"
                    tools:text="Just now" />
            </LinearLayout>

            <!-- Body (single line) -->
            <TextView
                android:id="@+id/tvNotifPopBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/adm_gray_500"
                android:textSize="11.5sp"
                tools:text="Your stay at The Grand Orchid Resort is confirmed." />
        </LinearLayout>

        <!-- Unread indicator dot -->
        <View
            android:id="@+id/notifPopUnreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_notif_dot_blue" />
    </LinearLayout>

    <!-- Hairline divider -->
    <View
        android:id="@+id/notifPopDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:background="@color/adm_gray_100" />
</FrameLayout>
