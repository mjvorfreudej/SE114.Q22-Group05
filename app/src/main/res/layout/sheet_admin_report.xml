<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_adm_sheet"
    android:orientation="vertical">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_adm_pill"
        android:backgroundTint="@color/adm_gray_200" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/adm_review_report"
            android:textColor="@color/adm_gray_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/admReportClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_adm_circle"
            android:backgroundTint="@color/adm_gray_100"
            android:contentDescription="@null"
            android:padding="7dp"
            android:src="@drawable/ic_close"
            app:tint="@color/adm_gray_700" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="18dp">

            <!-- Report banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_adm_rounded_12"
                android:backgroundTint="@color/adm_red_100"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_flag"
                    app:tint="@color/adm_red_700" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/admReportKindTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/adm_red_700"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/admReportMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/adm_gray_700"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Original content -->
            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_original_content" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_adm_rounded_12"
                android:backgroundTint="@color/adm_gray_50"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/admReportAvatar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/admReportTargetName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/adm_gray_900"
                            android:textSize="11.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/admReportContext"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/adm_gray_400"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/admReportBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/adm_gray_700"
                    android:textSize="12sp"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- Reasoning -->
            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_reporter_reasoning" />

            <TextView
                android:id="@+id/admReportReasoning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_adm_rounded_12"
                android:backgroundTint="@color/adm_gray_50"
                android:lineSpacingMultiplier="1.4"
                android:padding="12dp"
                android:textColor="@color/adm_gray_700"
                android:textSize="12sp" />

            <!-- Actions -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/admBtnContactBoth"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/adm_contact_both"
                android:textAllCaps="false"
                android:textColor="@color/adm_gray_900"
                app:cornerRadius="999dp"
                app:icon="@drawable/ic_mail"
                app:iconGravity="textStart"
                app:iconSize="14dp"
                app:iconTint="@color/adm_gray_900"
                app:strokeColor="@color/adm_gray_300" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admBtnDismiss"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/adm_dismiss"
                    android:textAllCaps="false"
                    android:textColor="@color/adm_gray_900"
                    app:cornerRadius="999dp"
                    app:strokeColor="@color/adm_gray_300" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admBtnApproveReport"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/adm_red_500"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/adm_approve_report"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:cornerRadius="999dp"
                    app:icon="@drawable/ic_ban"
                    app:iconGravity="textStart"
                    app:iconSize="14dp"
                    app:iconTint="@color/white" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
