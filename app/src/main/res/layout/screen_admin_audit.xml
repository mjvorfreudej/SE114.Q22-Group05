<?xml version="1.0" encoding="utf-8"?>
<!-- Admin › Audit log detail screen. Sticky segmented filter chips over a
     day-grouped timeline of admin actions (filled live from GET /admin/audit-log).
     Header export action is shown by AdminDetailActivity. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adm_canvas"
    android:orientation="vertical">

    <include layout="@layout/view_admin_detail_bar" />

    <!-- Sticky filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/admChipAll"
                style="@style/AdmFilterChip"
                android:text="@string/adm_tab_all" />

            <TextView
                android:id="@+id/admChipApprovals"
                style="@style/AdmFilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/adm_audit_filter_approvals" />

            <TextView
                android:id="@+id/admChipLocks"
                style="@style/AdmFilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/adm_audit_filter_locks" />

            <TextView
                android:id="@+id/admChipSettings"
                style="@style/AdmFilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/adm_audit_filter_settings" />
        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/adm_gray_100" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/admAuditContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp" />
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
