<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/admBizIconWrap"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_adm_rounded_10"
                android:backgroundTint="@color/adm_blue_50">

                <ImageView
                    android:id="@+id/admBizIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_building"
                    app:tint="@color/adm_blue_500" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/admBizName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/adm_gray_900"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/admBizMore"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@null"
                        android:padding="7dp"
                        android:src="@drawable/ic_more_vert"
                        app:tint="@color/adm_gray_700" />
                </LinearLayout>

                <TextView
                    android:id="@+id/admBizOwner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/adm_gray_500"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="@color/adm_gray_100" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/admBizListingsN"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/adm_gray_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="12dp"
                android:text="@string/adm_listings_label"
                android:textColor="@color/adm_gray_500"
                android:textSize="10.5sp" />

            <TextView
                android:id="@+id/admBizBookingsN"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/adm_gray_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/adm_bookings_label"
                android:textColor="@color/adm_gray_500"
                android:textSize="10.5sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/admBizStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_adm_pill"
                android:backgroundTint="@color/adm_green_100"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <View
                    android:id="@+id/admBizStatusDot"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_adm_circle"
                    android:backgroundTint="@color/adm_green_500" />

                <TextView
                    android:id="@+id/admBizStatusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/adm_green_700"
                    android:textSize="10.5sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons (Shown only for pending businesses) -->
        <LinearLayout
            android:id="@+id/layoutPendingActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApproveBiz"
                style="@style/Widget.Material3.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:backgroundTint="@color/adm_green_500"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Phê duyệt"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRejectBiz"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Từ chối"
                android:textColor="@color/adm_red_500"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:strokeColor="@color/adm_red_100" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
