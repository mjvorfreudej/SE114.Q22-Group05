<?xml version="1.0" encoding="utf-8"?>
<!-- Audit-log timeline entry: status dot + vertical connector · actor/action
     sentence · day · time meta. Connector is hidden on the last entry in code. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="30dp"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/admTlIconWrap"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_adm_circle"
            android:backgroundTint="@color/adm_gray_100">

            <ImageView
                android:id="@+id/admTlIcon"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_check"
                app:tint="@color/adm_gray_700" />
        </FrameLayout>

        <View
            android:id="@+id/admTlConnector"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:background="@color/adm_gray_100" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="1dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/admTlText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.4"
            android:textColor="@color/adm_gray_700"
            android:textSize="12.5sp" />

        <TextView
            android:id="@+id/admTlMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/adm_gray_400"
            android:textSize="10.5sp" />
    </LinearLayout>
</LinearLayout>
