<?xml version="1.0" encoding="utf-8"?>
<!-- Single-choice settings row (used by the Language picker): label + check mark. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_adm_rounded_12"
    android:backgroundTint="@color/adm_gray_50"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:id="@+id/admSelectTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/adm_gray_900"
        android:textSize="13.5sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/admSelectCheck"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_check"
        android:visibility="invisible"
        app:tint="@color/adm_blue_500" />
</LinearLayout>
