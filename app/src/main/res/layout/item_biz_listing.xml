<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bizListingCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_biz_listing_card"
    android:elevation="2dp"
    android:orientation="horizontal"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="88dp"
        android:layout_height="88dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/bizListingPhoto"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Biz.Corner10" />

        <FrameLayout
            android:id="@+id/bizListingCheck"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="5dp"
            android:background="@drawable/bg_biz_rounded_6"
            android:backgroundTint="#D9FFFFFF"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/bizListingCheckIcon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_check"
                android:visibility="invisible"
                app:tint="@color/white" />
        </FrameLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title + kebab -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bizListingName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/adm_gray_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/bizListingMenu"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:padding="6dp"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/adm_gray_600" />
        </LinearLayout>

        <!-- Location -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_location_20"
                app:tint="@color/adm_gray_500" />

            <TextView
                android:id="@+id/bizListingLoc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/adm_gray_500"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/bizListingCatChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_adm_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp">

                <View
                    android:id="@+id/bizListingCatDot"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_adm_circle" />

                <TextView
                    android:id="@+id/bizListingCatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bizListingStatusPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_adm_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp">

                <View
                    android:id="@+id/bizListingStatusDot"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_adm_circle" />

                <TextView
                    android:id="@+id/bizListingStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Price + stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1"
            android:gravity="bottom|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bizListingPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/adm_gray_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/bizListingStarIcon"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="3dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_star"
                app:tint="#FDB022" />

            <TextView
                android:id="@+id/bizListingRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textColor="@color/adm_gray_500"
                android:textSize="10.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bizListingBookings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/adm_gray_500"
                android:textSize="10.5sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
