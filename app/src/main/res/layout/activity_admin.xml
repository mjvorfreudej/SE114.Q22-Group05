<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adm_gray_100">

    <FrameLayout
        android:id="@+id/adm_fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/admBottomNavWrap"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/admBottomNavWrap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/adm_gray_100" />

        <LinearLayout
            android:id="@+id/admBottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="10dp">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/admTabHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <ImageView
                    android:id="@+id/admIconHome"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/adm_nav_home"
                    android:src="@drawable/ic_home_24"
                    app:tint="@color/adm_gray_400" />

                <TextView
                    android:id="@+id/admLabelHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/adm_nav_home"
                    android:textColor="@color/adm_gray_400"
                    android:textSize="10sp" />

                <View
                    android:id="@+id/admIndHome"
                    android:layout_width="16dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="3dp"
                    android:background="@drawable/bg_adm_pill"
                    android:backgroundTint="@color/adm_gray_900"
                    android:visibility="invisible" />
            </LinearLayout>

            <!-- Moderate (with badge) -->
            <LinearLayout
                android:id="@+id/admTabModerate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/admIconModerate"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@string/adm_nav_moderate"
                        android:src="@drawable/ic_gavel"
                        app:tint="@color/adm_gray_400" />

                    <TextView
                        android:id="@+id/admBadgeModerate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginStart="10dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_adm_pill"
                        android:backgroundTint="@color/adm_red_500"
                        android:minWidth="16dp"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="1dp"
                        android:text="23"
                        android:textColor="@color/white"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        tools:ignore="HardcodedText" />
                </FrameLayout>

                <TextView
                    android:id="@+id/admLabelModerate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/adm_nav_moderate"
                    android:textColor="@color/adm_gray_400"
                    android:textSize="10sp" />

                <View
                    android:id="@+id/admIndModerate"
                    android:layout_width="16dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="3dp"
                    android:background="@drawable/bg_adm_pill"
                    android:backgroundTint="@color/adm_gray_900"
                    android:visibility="invisible" />
            </LinearLayout>

            <!-- Business -->
            <LinearLayout
                android:id="@+id/admTabBusiness"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <ImageView
                    android:id="@+id/admIconBusiness"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/adm_nav_business"
                    android:src="@drawable/ic_building"
                    app:tint="@color/adm_gray_400" />

                <TextView
                    android:id="@+id/admLabelBusiness"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/adm_nav_business"
                    android:textColor="@color/adm_gray_400"
                    android:textSize="10sp" />

                <View
                    android:id="@+id/admIndBusiness"
                    android:layout_width="16dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="3dp"
                    android:background="@drawable/bg_adm_pill"
                    android:backgroundTint="@color/adm_gray_900"
                    android:visibility="invisible" />
            </LinearLayout>

            <!-- Users -->
            <LinearLayout
                android:id="@+id/admTabUsers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <ImageView
                    android:id="@+id/admIconUsers"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/adm_nav_users"
                    android:src="@drawable/ic_users"
                    app:tint="@color/adm_gray_400" />

                <TextView
                    android:id="@+id/admLabelUsers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/adm_nav_users"
                    android:textColor="@color/adm_gray_400"
                    android:textSize="10sp" />

                <View
                    android:id="@+id/admIndUsers"
                    android:layout_width="16dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="3dp"
                    android:background="@drawable/bg_adm_pill"
                    android:backgroundTint="@color/adm_gray_900"
                    android:visibility="invisible" />
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/admTabProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <ImageView
                    android:id="@+id/admIconProfile"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/adm_nav_profile"
                    android:src="@drawable/ic_person_24"
                    app:tint="@color/adm_gray_400" />

                <TextView
                    android:id="@+id/admLabelProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/adm_nav_profile"
                    android:textColor="@color/adm_gray_400"
                    android:textSize="10sp" />

                <View
                    android:id="@+id/admIndProfile"
                    android:layout_width="16dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="3dp"
                    android:background="@drawable/bg_adm_pill"
                    android:backgroundTint="@color/adm_gray_900"
                    android:visibility="invisible" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
