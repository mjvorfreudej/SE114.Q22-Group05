<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="6dp"
    android:background="@drawable/bg_adm_pill"
    android:backgroundTint="@color/adm_gray_100"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/admTabLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/adm_gray_700"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/admTabCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_adm_pill"
        android:backgroundTint="@color/white"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="@color/adm_gray_500"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>
