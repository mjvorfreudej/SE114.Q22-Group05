<?xml version="1.0" encoding="utf-8"?>
<!--
  Traveler notification center — recreated from ui_kits/notifications/traveler.html
  (the canonical full-screen "Notification" surface: app bar · filters · date-grouped
  list, with loading / empty states). White page, Urbanist type, one accent blue.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- ── App bar: back · (title + unread count) · kebab ───────────────── -->
    <LinearLayout
        android:id="@+id/notifAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:id="@+id/btnNotifBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_adm_pill"
            android:backgroundTint="@color/adm_gray_100"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_back"
                app:tint="@color/adm_gray_900" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNotifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notif_title"
                android:textColor="@color/adm_gray_900"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvNotifUnread"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/adm_gray_400"
                android:textSize="10.5sp"
                tools:text="3 chưa đọc"
                android:visibility="gone" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnNotifMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/notif_settings"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/adm_gray_600" />
        </FrameLayout>
    </LinearLayout>

    <!-- ── Filters: horizontally scrolling chip row + 1px bottom border ─── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/rowNotifFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="2dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/adm_gray_100" />

    <!-- ── Content: list · loading skeleton · empty state ───────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNotifications"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="24dp"
            android:scrollbars="none" />

        <!-- Loading skeleton (rows inflated in code) -->
        <LinearLayout
            android:id="@+id/skeletonContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:visibility="gone" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_adm_rounded_16"
                android:backgroundTint="@color/adm_gray_100">

                <ImageView
                    android:id="@+id/ivEmptyIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_inbox"
                    app:tint="@color/adm_gray_400" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmptyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notif_empty_all_title"
                android:textColor="@color/adm_gray_900"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvEmptyMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:maxWidth="240dp"
                android:text="@string/notif_empty_all_msg"
                android:textColor="@color/adm_gray_500"
                android:textSize="12.5sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
