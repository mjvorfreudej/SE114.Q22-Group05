<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/screen_margin_horizontal"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/profile_logout_title"
        android:textColor="#E53935"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/profile_logout_confirm"
        android:textColor="@color/dark_gray"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogoutCancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:maxLines="1"
            android:paddingHorizontal="8dp"
            android:text="@string/action_cancel"
            android:textAllCaps="false"
            android:textColor="@color/black"
            app:cornerRadius="999dp"
            app:strokeColor="@color/black"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogoutConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/gutter_space"
            android:layout_weight="1"
            android:backgroundTint="@color/black"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:maxLines="1"
            android:paddingHorizontal="8dp"
            android:text="@string/profile_logout_confirm_btn"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="999dp" />
    </LinearLayout>
</LinearLayout>
