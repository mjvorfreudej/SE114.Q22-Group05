<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootCreateTour"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_circle_soft"
            android:gravity="center"
            android:text="‹"
            android:textColor="#101828"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Listing"
                android:textColor="#101828"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Step 1 of 5"
                android:textColor="#98A2B3"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnDemo"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="Demo"
            android:textColor="#F79009"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSaveDraft"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="Save Draft"
            android:textColor="#2E90FA"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvStepCircle1"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_step_current"
                android:gravity="center"
                android:text="1"
                android:textColor="#101828"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/lineStep1"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#F2F4F7" />

            <TextView
                android:id="@+id/tvStepCircle2"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="2"
                android:textColor="#98A2B3"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/lineStep2"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#F2F4F7" />

            <TextView
                android:id="@+id/tvStepCircle3"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="3"
                android:textColor="#98A2B3"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/lineStep3"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#F2F4F7" />

            <TextView
                android:id="@+id/tvStepCircle4"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="4"
                android:textColor="#98A2B3"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/lineStep4"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#F2F4F7" />

            <TextView
                android:id="@+id/tvStepCircle5"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="5"
                android:textColor="#98A2B3"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvStepLabel1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="Basic"
                android:textColor="#101828"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStepLabel2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Location"
                android:textColor="#98A2B3"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvStepLabel3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Pricing"
                android:textColor="#98A2B3"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvStepLabel4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Calendar"
                android:textColor="#98A2B3"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvStepLabel5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="Review"
                android:textColor="#98A2B3"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="22dp">

            <LinearLayout
                android:id="@+id/stepBasic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tell us the basics"
                    android:textColor="#101828"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Pick a category and give your listing a name."
                    android:textColor="#667085"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Category"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layoutHotel"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_listing_option"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_listing_icon_orange"
                            android:gravity="center"
                            android:text="▣"
                            android:textColor="#F79009"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hotel"
                                android:textColor="#101828"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rooms &amp; stays"
                                android:textColor="#98A2B3"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:id="@+id/layoutTour"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_listing_option_selected"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_listing_icon_blue"
                            android:gravity="center"
                            android:text="◇"
                            android:textColor="#2E90FA"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tour"
                                android:textColor="#101828"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Guided activities"
                                android:textColor="#98A2B3"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Listing name"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtTourName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_listing_input"
                    android:hint="The Grand Orchid Resort"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:singleLine="true"
                    android:textColor="#101828"
                    android:textColorHint="#98A2B3"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Description"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_listing_input"
                    android:gravity="top"
                    android:hint="A short description of your listing..."
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="12dp"
                    android:textColor="#101828"
                    android:textColorHint="#98A2B3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPhotoCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Photos · 0/6"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvImages"
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:layout_marginTop="8dp"
                    android:overScrollMode="never" />

                <TextView
                    android:id="@+id/btnUploadImage"
                    android:layout_width="96dp"
                    android:layout_height="88dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_listing_upload"
                    android:gravity="center"
                    android:text="↥\nUpload"
                    android:textColor="#667085"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stepLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Where &amp; what's included"
                    android:textColor="#101828"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Help guests find you and know what to expect."
                    android:textColor="#667085"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Address"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtDestination"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_listing_input"
                    android:hint="Bangkok, Thailand"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:singleLine="true"
                    android:textColor="#101828"
                    android:textColorHint="#98A2B3"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edtRegion"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_listing_input"
                    android:hint="Region. Example: Southeast Asia"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:singleLine="true"
                    android:textColor="#101828"
                    android:textColorHint="#98A2B3"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtLatitude"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_listing_input"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:hint="13.7563"
                        android:textColor="#101828"
                        android:textSize="14sp" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:id="@+id/edtLongitude"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_listing_input"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:hint="100.5018"
                        android:textColor="#101828"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="126dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_listing_map"
                    android:gravity="center"
                    android:text="●\nMap preview"
                    android:textColor="#101828"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Amenities / Highlights"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:text="  Wi-Fi      Pool      Parking      Breakfast"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center_vertical"
                    android:text="  Workspace      A/C"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Capacity (guests)"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnMinusCapacity"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_soft"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="#101828"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/tvCapacity"
                        android:layout_width="60dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="4"
                        android:textColor="#101828"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnPlusCapacity"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_soft"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="#101828"
                        android:textSize="22sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stepPricing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Set your pricing"
                    android:textColor="#101828"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="You can adjust seasonal rates and fees below."
                    android:textColor="#667085"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Base price"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtPrice"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_listing_input"
                    android:gravity="center"
                    android:hint="199"
                    android:inputType="numberDecimal"
                    android:textColor="#101828"
                    android:textColorHint="#101828"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/edtDuration"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_listing_input"
                    android:hint="Duration. Example: 3 Days 2 Nights"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:singleLine="true"
                    android:textColor="#101828"
                    android:textColorHint="#98A2B3"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_listing_card"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="⚙  Seasonal rates                                    ●"
                    android:textColor="#101828"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_listing_card"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Peak season        Dec 1 – Feb 28                         +25%"
                    android:textColor="#101828"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_listing_card"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Mid season         Mar 1 – May 31                         ±0%"
                    android:textColor="#101828"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_listing_card"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Off-peak           Jun 1 – Nov 30                         −15%"
                    android:textColor="#101828"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Extra fees"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_listing_card"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Cleaning fee                                             $25"
                    android:textColor="#101828"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stepPublishSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pick your availability"
                    android:textColor="#101828"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Mark dates as open, blocked, or part of a custom range."
                    android:textColor="#667085"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Date range"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvOpenFrom"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_listing_input"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:text="▣   Open from"
                        android:textColor="#667085"
                        android:textSize="13sp" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvOpenUntil"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_listing_input"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:text="▣   Open until"
                        android:textColor="#667085"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_listing_card"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Month header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnPrevMonth"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_soft"
                            android:gravity="center"
                            android:text="‹"
                            android:textColor="#101828"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCurrentMonth"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="August 2025"
                            android:textColor="#101828"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnNextMonth"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_soft"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#101828"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TableLayout
                        android:id="@+id/tableCalendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:stretchColumns="*">

                        <TableRow>
                            <TextView android:gravity="center" android:text="S" android:textColor="#98A2B3" android:textSize="11sp" />
                            <TextView android:gravity="center" android:text="M" android:textColor="#98A2B3" android:textSize="11sp" />
                            <TextView android:gravity="center" android:text="T" android:textColor="#98A2B3" android:textSize="11sp" />
                            <TextView android:gravity="center" android:text="W" android:textColor="#98A2B3" android:textSize="11sp" />
                            <TextView android:gravity="center" android:text="T" android:textColor="#98A2B3" android:textSize="11sp" />
                            <TextView android:gravity="center" android:text="F" android:textColor="#98A2B3" android:textSize="11sp" />
                            <TextView android:gravity="center" android:text="S" android:textColor="#98A2B3" android:textSize="11sp" />
                        </TableRow>
                    </TableLayout>

                    <!-- Legend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="■ Selected"
                            android:textColor="#101828"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:text="▧ Blocked"
                            android:textColor="#D92D20"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:text="□ Open"
                            android:textColor="#101828"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_listing_upload"
                    android:gravity="center"
                    android:text="+  Block additional dates"
                    android:textColor="#101828"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stepReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Review &amp; publish"
                    android:textColor="#101828"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Double-check everything below. You can edit later."
                    android:textColor="#667085"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_listing_card"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="132dp">

                        <ImageView
                            android:id="@+id/imgReviewCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="#EAECF0" />

                        <TextView
                            android:id="@+id/tvTourTag"
                            android:layout_width="wrap_content"
                            android:layout_height="26dp"
                            android:layout_margin="10dp"
                            android:background="@drawable/bg_listing_option_selected"
                            android:gravity="center"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="Tour"
                            android:textColor="#101828"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvReviewName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="The Grand Orchid Resort"
                            android:textColor="#101828"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvReviewDestination"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="Bangkok, Thailand"
                            android:textColor="#667085"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvReviewPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="$199 / night"
                            android:textColor="#101828"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvReviewImages"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_listing_card"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Photos                                      3 added"
                    android:textColor="#101828"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvReviewAmenities"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_listing_card"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Amenities                                  Wi-Fi, Pool"
                    android:textColor="#101828"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvReviewDuration"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_listing_card"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Duration                                  3 Days 2 Nights"
                    android:textColor="#101828"
                    android:textSize="13sp" />

                <CheckBox
                    android:id="@+id/cbAgree"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="I agree to TourGo's Host Terms and confirm this listing complies with local regulations."
                    android:textColor="#101828"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/btnCancelBottom"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_listing_secondary"
            android:gravity="center"
            android:text="‹  Cancel"
            android:textColor="#101828"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/btnContinue"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:background="@drawable/bg_listing_primary"
            android:gravity="center"
            android:text="Continue  ›"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
