<?xml version="1.0" encoding="utf-8"?>
<!-- Shared scaffold for the Admin › Settings bottom sheets (moderation policy,
     admin team, audit log, language, password & 2FA, help). The body is filled
     programmatically per row in AdminProfileFragment. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_adm_sheet"
    android:orientation="vertical">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_adm_pill"
        android:backgroundTint="@color/adm_gray_200" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_adm_rounded_8"
            android:backgroundTint="@color/adm_gray_100">

            <ImageView
                android:id="@+id/admSheetIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_gavel"
                app:tint="@color/adm_gray_700" />
        </FrameLayout>

        <TextView
            android:id="@+id/admSheetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:textColor="@color/adm_gray_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/admSheetClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_adm_circle"
            android:backgroundTint="@color/adm_gray_100"
            android:contentDescription="@null"
            android:padding="7dp"
            android:src="@drawable/ic_close"
            app:tint="@color/adm_gray_700" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/admSheetBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="2dp"
            android:paddingBottom="20dp" />
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
