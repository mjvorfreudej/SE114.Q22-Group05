<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_adm_rounded_12"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_adm_rounded_8"
        android:backgroundTint="@color/adm_gray_100">

        <ImageView
            android:id="@+id/bizRowIcon"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            app:tint="@color/adm_gray_600" />
    </FrameLayout>

    <TextView
        android:id="@+id/bizRowLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:textColor="@color/adm_gray_900"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/bizRowTrailing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:textColor="@color/adm_gray_400"
        android:textSize="11.5sp"
        android:visibility="gone" />

    <ImageView
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_chevron_right_24"
        app:tint="@color/adm_gray_400" />
</LinearLayout>
