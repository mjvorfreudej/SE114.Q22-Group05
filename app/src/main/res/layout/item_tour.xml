<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_profile_card"
    android:padding="12dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTourImg"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgTour"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/hotel_1"
            android:contentDescription="@string/app_name" />
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/btnFavoriteTour"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_circle_white_alpha"
        android:clickable="true"
        android:contentDescription="@string/app_name"
        android:focusable="true"
        android:padding="6dp"
        android:src="@drawable/ic_heart_filled"
        app:layout_constraintEnd_toEndOf="@id/cardTourImg"
        app:layout_constraintTop_toTopOf="@id/cardTourImg"
        app:tint="@android:color/white" />

    <TextView
        android:id="@+id/tvTourName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Bali Sunset Escape"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardTourImg" />

    <ImageView
        android:id="@+id/icLocation"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginTop="6dp"
        android:src="@drawable/ic_location_20"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTourName"
        app:tint="@color/dark_gray"
        android:contentDescription="@string/app_name" />

    <TextView
        android:id="@+id/tvTourLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:text="Bali, Indonesia"
        android:textColor="@color/dark_gray"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@id/icLocation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/icLocation"
        app:layout_constraintTop_toTopOf="@id/icLocation" />

    <TextView
        android:id="@+id/tvTourPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="$199"
        android:textColor="@color/light_blue"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTourLocation" />

    <TextView
        android:id="@+id/tvTourDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="• 3 Days 2 Nights"
        android:textColor="@color/dark_gray"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@id/tvTourPrice"
        app:layout_constraintStart_toEndOf="@id/tvTourPrice"
        app:layout_constraintTop_toTopOf="@id/tvTourPrice" />

    <TextView
        android:id="@+id/tvTourRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="★ 4.8"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvTourPrice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTourPrice" />

    <TextView
        android:id="@+id/tvTourStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_status_pending"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="PENDING"
        android:textColor="#F59E0B"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/tvTourPrice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTourPrice" />

</androidx.constraintlayout.widget.ConstraintLayout>