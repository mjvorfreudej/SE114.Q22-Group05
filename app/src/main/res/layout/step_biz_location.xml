<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView style="@style/BizStepHeading" android:text="@string/biz_s2_title" />
    <TextView style="@style/BizStepSub" android:text="@string/biz_s2_sub" />

    <!-- City & Address -->
    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="City" />
    <EditText
        style="@style/BizInput"
        android:id="@+id/bizCity"
        android:hint="e.g. Da Lat"
        android:inputType="text" />

    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="@string/biz_address" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_biz_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_location_20"
            app:tint="@color/adm_gray_400" />

        <EditText
            android:id="@+id/bizAddress"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="@string/biz_address_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/adm_gray_900"
            android:textColorHint="@color/adm_gray_400"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Lat / Long -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView style="@style/BizFieldLabel" android:text="@string/biz_latitude" />

            <EditText
                style="@style/BizInput"
                android:hint="13.7563"
                android:importantForAutofill="no"
                android:inputType="numberDecimal"
                tools:ignore="HardcodedText"
                xmlns:tools="http://schemas.android.com/tools" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView style="@style/BizFieldLabel" android:text="@string/biz_longitude" />

            <EditText
                style="@style/BizInput"
                android:hint="100.5018"
                android:importantForAutofill="no"
                android:inputType="numberDecimal"
                tools:ignore="HardcodedText"
                xmlns:tools="http://schemas.android.com/tools" />
        </LinearLayout>
    </LinearLayout>

    <!-- Map preview -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_biz_map">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_location_20"
            app:tint="@color/adm_gray_900" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/bg_adm_pill"
            android:backgroundTint="#E0FFFFFF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="@string/biz_map_preview"
            android:textColor="@color/adm_blue_700"
            android:textSize="10sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Amenities -->
    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="@string/biz_amenities" />

    <GridLayout
        android:id="@+id/bizAmenities"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3" />

    <!-- Capacity -->
    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="@string/biz_capacity" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_adm_pill"
        android:backgroundTint="@color/adm_gray_100"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp">

        <FrameLayout
            android:id="@+id/bizCapacityMinus"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_adm_circle"
            android:backgroundTint="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:elevation="1dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_minus"
                app:tint="@color/adm_gray_900" />
        </FrameLayout>

        <TextView
            android:id="@+id/bizCapacityText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="4"
            android:textColor="@color/adm_gray_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/bizCapacityPlus"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_adm_circle"
            android:backgroundTint="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:elevation="1dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_plus"
                app:tint="@color/adm_gray_900" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
