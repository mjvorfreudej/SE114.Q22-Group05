<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adm_gray_100"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/biz_account"
            android:textColor="@color/adm_gray_400"
            android:textSize="10.5sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/biz_profile"
            android:textColor="@color/adm_gray_900"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="96dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_adm_rounded_14"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/bizProfileAvatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/bizProfileOwnerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/biz_owner_name"
                        android:textColor="@color/adm_gray_900"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/bizProfileOrgName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/biz_org_name"
                        android:textColor="@color/adm_gray_500"
                        android:textSize="11.5sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_adm_pill"
                        android:backgroundTint="@color/adm_green_100"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp">

                        <ImageView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_shield_check"
                            app:tint="@color/adm_green_700" />

                        <TextView
                            android:id="@+id/bizProfileStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/biz_verified_business"
                            android:textColor="@color/adm_green_700"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_adm_circle"
                    android:backgroundTint="@color/adm_gray_100"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/adm_gray_900" />
                </FrameLayout>
            </LinearLayout>

            <!-- Mini stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    style="@style/BizMiniStat"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/bizProfileListingsVal"
                        style="@style/BizMiniStatValue"
                        android:text="12"
                        tools:ignore="HardcodedText" />

                    <TextView style="@style/BizMiniStatLabel" android:text="@string/biz_stat_listings_short" />
                </LinearLayout>

                <LinearLayout
                    style="@style/BizMiniStat"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/bizProfileBookingsVal"
                        style="@style/BizMiniStatValue"
                        android:text="286"
                        tools:ignore="HardcodedText" />

                    <TextView style="@style/BizMiniStatLabel" android:text="@string/biz_stat_bookings_short" />
                </LinearLayout>

                <LinearLayout
                    style="@style/BizMiniStat"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:id="@+id/bizProfileRatingVal"
                        style="@style/BizMiniStatValue"
                        android:text="4.8"
                        tools:ignore="HardcodedText" />

                    <TextView style="@style/BizMiniStatLabel" android:text="@string/biz_stat_rating_short" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/BizProfileSection"
                android:text="@string/biz_section_business" />

            <LinearLayout
                android:id="@+id/bizBusinessRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                style="@style/BizProfileSection"
                android:layout_marginTop="16dp"
                android:text="@string/biz_section_preferences" />

            <LinearLayout
                android:id="@+id/bizPrefRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Logout (matches the Traveler/Admin red-outline card style) -->
            <LinearLayout
                android:id="@+id/bizLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_adm_logout"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_logout_24"
                    app:tint="@color/adm_red_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/biz_logout"
                    android:textColor="@color/adm_red_500"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
