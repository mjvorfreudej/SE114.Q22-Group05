<?xml version="1.0" encoding="utf-8"?>
<!-- Admin › Admin team & roles detail screen. Tinted summary banner, live
     member directory (avatars + role badges + ⋮ menu), a pending invite card
     and a sticky Invite admin CTA. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adm_canvas"
    android:orientation="vertical">

    <include layout="@layout/view_admin_detail_bar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <!-- Summary banner (blue-50, no shadow) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/adm_blue_50"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_adm_rounded_12"
                        android:backgroundTint="@color/white">

                        <ImageView
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_users"
                            app:tint="@color/adm_blue_500" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/admTeamSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/adm_blue_700"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:lineSpacingMultiplier="1.35"
                            android:text="@string/adm_team_summary_sub"
                            android:textColor="@color/adm_gray_700"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_team_members" />

            <com.google.android.material.card.MaterialCardView
                style="@style/AdmDetailCard">

                <LinearLayout
                    android:id="@+id/admTeamMembers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_team_pending" />

            <!-- Pending invite (static demo — no invites API yet) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AdmDetailCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_adm_rounded_12"
                        android:backgroundTint="@color/adm_amber_100">

                        <ImageView
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_mail"
                            app:tint="@color/adm_amber_500" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="sofia@tourgo.app"
                            android:textColor="@color/adm_gray_900"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/adm_team_pending_meta"
                            android:textColor="@color/adm_gray_400"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_adm_pill"
                        android:backgroundTint="@color/adm_amber_100"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="4dp"
                        android:text="@string/adm_team_pending_chip"
                        android:textColor="@color/adm_amber_700"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Invite footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/admTeamInvite"
            style="@style/AdmPrimaryButton"
            app:icon="@drawable/ic_plus"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            android:text="@string/adm_team_invite_admin" />
    </LinearLayout>
</LinearLayout>
