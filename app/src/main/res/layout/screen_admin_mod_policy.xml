<?xml version="1.0" encoding="utf-8"?>
<!-- Admin › Moderation policy detail screen. Automated rule toggles, numeric
     thresholds (steppers) and a restricted-terms list, capped by a sticky Save. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adm_canvas"
    android:orientation="vertical">

    <include layout="@layout/view_admin_detail_bar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_policy_automated_rules" />

            <com.google.android.material.card.MaterialCardView
                style="@style/AdmDetailCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp">

                    <!-- Auto-hide reported content (blue tile) -->
                    <LinearLayout style="@style/AdmToggleRow">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_adm_rounded_8"
                            android:backgroundTint="@color/adm_blue_50">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_shield_check"
                                app:tint="@color/adm_blue_500" />
                        </FrameLayout>

                        <LinearLayout style="@style/AdmRowText">

                            <TextView
                                style="@style/AdmRowTitle"
                                android:text="@string/adm_policy_autohide_title" />

                            <TextView
                                style="@style/AdmRowSub"
                                android:text="@string/adm_policy_autohide_sub" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/admPolicyAutohide"
                            style="@style/AdmSwitch"
                            android:checked="true" />
                    </LinearLayout>

                    <View style="@style/AdmRowDivider" />

                    <!-- Profanity & spam filter -->
                    <LinearLayout style="@style/AdmToggleRow">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_adm_rounded_8"
                            android:backgroundTint="@color/adm_gray_100">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_ban"
                                app:tint="@color/adm_gray_700" />
                        </FrameLayout>

                        <LinearLayout style="@style/AdmRowText">

                            <TextView
                                style="@style/AdmRowTitle"
                                android:text="@string/adm_policy_profanity_title" />

                            <TextView
                                style="@style/AdmRowSub"
                                android:text="@string/adm_policy_profanity_sub" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/admPolicyProfanity"
                            style="@style/AdmSwitch"
                            android:checked="true" />
                    </LinearLayout>

                    <View style="@style/AdmRowDivider" />

                    <!-- Require photo approval -->
                    <LinearLayout style="@style/AdmToggleRow">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_adm_rounded_8"
                            android:backgroundTint="@color/adm_gray_100">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_image"
                                app:tint="@color/adm_gray_700" />
                        </FrameLayout>

                        <LinearLayout style="@style/AdmRowText">

                            <TextView
                                style="@style/AdmRowTitle"
                                android:text="@string/adm_policy_photo_title" />

                            <TextView
                                style="@style/AdmRowSub"
                                android:text="@string/adm_policy_photo_sub" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/admPolicyPhoto"
                            style="@style/AdmSwitch" />
                    </LinearLayout>

                    <View style="@style/AdmRowDivider" />

                    <!-- Geo-restriction check -->
                    <LinearLayout style="@style/AdmToggleRow">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_adm_rounded_8"
                            android:backgroundTint="@color/adm_gray_100">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_map"
                                app:tint="@color/adm_gray_700" />
                        </FrameLayout>

                        <LinearLayout style="@style/AdmRowText">

                            <TextView
                                style="@style/AdmRowTitle"
                                android:text="@string/adm_policy_geo_title" />

                            <TextView
                                style="@style/AdmRowSub"
                                android:text="@string/adm_policy_geo_sub" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/admPolicyGeo"
                            style="@style/AdmSwitch" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_policy_thresholds" />

            <com.google.android.material.card.MaterialCardView
                style="@style/AdmDetailCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp">

                    <!-- Auto-hide after (amber tile) + stepper -->
                    <LinearLayout style="@style/AdmToggleRow">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_adm_rounded_8"
                            android:backgroundTint="@color/adm_amber_100">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_flag"
                                app:tint="@color/adm_amber_500" />
                        </FrameLayout>

                        <LinearLayout style="@style/AdmRowText">

                            <TextView
                                style="@style/AdmRowTitle"
                                android:text="@string/adm_policy_autohide_after_title" />

                            <TextView
                                style="@style/AdmRowSub"
                                android:text="@string/adm_policy_autohide_after_sub" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/admHideAtMinus"
                                style="@style/AdmStepperBtn"
                                android:src="@drawable/ic_minus" />

                            <TextView
                                android:id="@+id/admHideAtValue"
                                style="@style/AdmStepperValue"
                                android:minWidth="24dp" />

                            <ImageView
                                android:id="@+id/admHideAtPlus"
                                style="@style/AdmStepperBtn"
                                android:src="@drawable/ic_plus" />
                        </LinearLayout>
                    </LinearLayout>

                    <View style="@style/AdmRowDivider" />

                    <!-- Review SLA + stepper (hours) -->
                    <LinearLayout style="@style/AdmToggleRow">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_adm_rounded_8"
                            android:backgroundTint="@color/adm_gray_100">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_time"
                                app:tint="@color/adm_gray_700" />
                        </FrameLayout>

                        <LinearLayout style="@style/AdmRowText">

                            <TextView
                                style="@style/AdmRowTitle"
                                android:text="@string/adm_policy_sla_title" />

                            <TextView
                                style="@style/AdmRowSub"
                                android:text="@string/adm_policy_sla_sub" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/admSlaMinus"
                                style="@style/AdmStepperBtn"
                                android:src="@drawable/ic_minus" />

                            <TextView
                                android:id="@+id/admSlaValue"
                                style="@style/AdmStepperValue"
                                android:minWidth="52dp" />

                            <ImageView
                                android:id="@+id/admSlaPlus"
                                style="@style/AdmStepperBtn"
                                android:src="@drawable/ic_plus" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_policy_restricted_terms" />

            <com.google.android.material.card.MaterialCardView
                style="@style/AdmDetailCard">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/admPolicyTerms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="8dp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Save footer -->
    <LinearLayout
        android:id="@+id/admDetailFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/admPolicySave"
            style="@style/AdmPrimaryButton"
            android:text="@string/adm_policy_save" />
    </LinearLayout>
</LinearLayout>
