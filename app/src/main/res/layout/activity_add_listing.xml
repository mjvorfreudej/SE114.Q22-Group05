<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adm_gray_100">

    <!-- App bar -->
    <LinearLayout
        android:id="@+id/bizAddAppbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/bizAddBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_adm_circle"
            android:backgroundTint="@color/adm_gray_100"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/biz_back"
                android:src="@drawable/ic_chevron_left_24"
                app:tint="@color/adm_gray_900" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/biz_new_listing"
                android:textColor="@color/adm_gray_900"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bizAddStepLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/adm_gray_400"
                android:textSize="10.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/bizAddSaveDraft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:text="@string/biz_save_draft"
            android:textColor="@color/adm_blue_500"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Stepper -->
    <LinearLayout
        android:id="@+id/bizStepper"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="6dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toBottomOf="@id/bizAddAppbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/bizStepperRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

        <LinearLayout
            android:id="@+id/bizStepperLabels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal" />
    </LinearLayout>

    <!-- Step content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/bizStepper"
        app:layout_constraintBottom_toTopOf="@id/bizAddNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/bizStepContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom nav -->
    <LinearLayout
        android:id="@+id/bizAddNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bizAddBackBtn"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:text="@string/biz_back"
            android:textAllCaps="false"
            android:textColor="@color/adm_gray_900"
            app:cornerRadius="999dp"
            app:icon="@drawable/ic_chevron_left_24"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconTint="@color/adm_gray_900"
            app:strokeColor="@color/adm_gray_300" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bizAddNextBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="@color/adm_gray_900"
            android:text="@string/biz_continue"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="999dp"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd"
            app:iconSize="16dp"
            app:iconTint="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
