<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_adm_sheet"
    android:orientation="vertical">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_adm_pill"
        android:backgroundTint="@color/adm_gray_200" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/biz_booking_details"
            android:textColor="@color/adm_gray_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/bizSheetClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_adm_circle"
            android:backgroundTint="@color/adm_gray_100"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:contentDescription="@string/biz_cancel"
                android:src="@drawable/ic_close"
                app:tint="@color/adm_gray_600" />
        </FrameLayout>
    </LinearLayout>

    <!-- Guest header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/bizDetailAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/bizDetailGuest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/adm_gray_900"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bizDetailRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/adm_gray_500"
                android:textSize="11.5sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/bizDetailStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_adm_pill"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="@color/adm_gray_100" />

    <!-- Check-in / Check-out tiles -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_adm_rounded_10"
            android:backgroundTint="@color/adm_gray_50"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/biz_checkin"
                android:textColor="@color/adm_gray_400"
                android:textSize="10.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bizDetailCheckin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/adm_gray_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bizDetailCheckinDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Aug 18"
                android:textColor="@color/adm_gray_500"
                android:textSize="10.5sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_adm_rounded_10"
            android:backgroundTint="@color/adm_gray_50"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/biz_checkout"
                android:textColor="@color/adm_gray_400"
                android:textSize="10.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bizDetailCheckout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/adm_gray_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bizDetailCheckoutDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Aug 20"
                android:textColor="@color/adm_gray_500"
                android:textSize="10.5sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>
    </LinearLayout>

    <!-- Summary rows -->
    <LinearLayout
        android:id="@+id/bizDetailSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp" />

    <!-- Late note -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_adm_rounded_10"
        android:backgroundTint="@color/adm_orange_50"
        android:gravity="top"
        android:orientation="horizontal"
        android:padding="10dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="1dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_time"
            app:tint="@color/adm_amber_700" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/biz_late_note"
            android:textColor="@color/adm_amber_700"
            android:textSize="11.5sp" />
    </LinearLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bizDetailContact"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:text="@string/biz_detail_contact"
            android:textAllCaps="false"
            android:textColor="@color/adm_gray_900"
            app:cornerRadius="999dp"
            app:icon="@drawable/ic_phone"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconTint="@color/adm_gray_900"
            app:strokeColor="@color/adm_gray_300" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bizDetailCheckinBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:backgroundTint="@color/adm_gray_900"
            android:text="@string/biz_mark_checkin"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="999dp"
            app:icon="@drawable/ic_check"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconTint="@color/white" />
    </LinearLayout>
</LinearLayout>
