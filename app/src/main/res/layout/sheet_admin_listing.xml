<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/adm_review_listing"
            android:textColor="@color/adm_gray_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/admListingClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_adm_circle"
            android:backgroundTint="@color/adm_gray_100"
            android:contentDescription="@null"
            android:padding="7dp"
            android:src="@drawable/ic_close"
            app:tint="@color/adm_gray_700" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="20dp">

            <!-- Hero -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="170dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/admListingPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:src="@drawable/hotel_1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/admListingCat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_adm_pill"
                            android:backgroundTint="@color/adm_amber_100"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp">

                            <View
                                android:id="@+id/admListingCatDot"
                                android:layout_width="5dp"
                                android:layout_height="5dp"
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_adm_circle"
                                android:backgroundTint="@color/adm_amber_500" />

                            <TextView
                                android:id="@+id/admListingCatLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/adm_orange_ink"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_adm_pill"
                            android:backgroundTint="#B3101828"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:text="@string/adm_awaiting_review"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/admListingName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/adm_gray_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_location_20"
                    app:tint="@color/adm_gray_500" />

                <TextView
                    android:id="@+id/admListingCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/adm_gray_500"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/admListingPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/adm_gray_900"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/admListingSubmitted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/adm_gray_500"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_description" />

            <TextView
                android:id="@+id/admListingDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/adm_gray_700"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4" />

            <!-- Business -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_adm_rounded_12"
                android:backgroundTint="@color/adm_gray_50"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_adm_rounded_10"
                    android:backgroundTint="@color/adm_blue_50">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_building"
                        app:tint="@color/adm_blue_500" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/admListingBusiness"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/adm_gray_900"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/adm_verified_business"
                        android:textColor="@color/adm_gray_500"
                        android:textSize="11sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admListingViewBiz"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="@string/adm_view"
                    android:textAllCaps="false"
                    android:textColor="@color/adm_gray_900"
                    android:textSize="11sp"
                    app:cornerRadius="999dp"
                    app:strokeColor="@color/adm_gray_200" />
            </LinearLayout>

            <!-- Admin notes -->
            <TextView
                style="@style/AdmSectionLabel"
                android:text="@string/adm_admin_notes" />

            <EditText
                android:id="@+id/admListingNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_adm_rounded_16"
                android:backgroundTint="@color/adm_gray_100"
                android:gravity="top"
                android:hint="@string/adm_admin_notes_hint"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:padding="14dp"
                android:textColor="@color/adm_gray_900"
                android:textColorHint="@color/adm_gray_400"
                android:textSize="13sp" />

            <!-- History -->
            <LinearLayout
                android:id="@+id/admListingHistorySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/AdmSectionLabel"
                    android:text="@string/adm_status_history" />

                <LinearLayout
                    android:id="@+id/admListingHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="10dp"
            android:background="@color/adm_gray_100" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/admBtnRevision"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/adm_request_revision"
                android:textAllCaps="false"
                android:textColor="@color/adm_gray_900"
                android:textSize="12sp"
                app:cornerRadius="999dp"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconSize="13dp"
                app:iconTint="@color/adm_gray_900"
                app:strokeColor="@color/adm_gray_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/admBtnReject"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/adm_red_500"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/adm_reject"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="999dp"
                app:icon="@drawable/ic_close"
                app:iconGravity="textStart"
                app:iconSize="13dp"
                app:iconTint="@color/white" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/admBtnApprove"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/adm_gray_900"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/adm_approve_publish"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp"
            app:cornerRadius="999dp"
            app:icon="@drawable/ic_check"
            app:iconGravity="textStart"
            app:iconSize="13dp"
            app:iconTint="@color/white" />
    </LinearLayout>
</LinearLayout>
