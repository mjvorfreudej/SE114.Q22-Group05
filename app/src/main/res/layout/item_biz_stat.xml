<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_adm_rounded_14"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/bizStatIconWrap"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_adm_rounded_8">

            <ImageView
                android:id="@+id/bizStatIcon"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center"
                android:contentDescription="@null" />
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/bizStatDelta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_adm_pill"
            android:backgroundTint="@color/adm_green_100"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:textColor="@color/adm_green_700"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/bizStatValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/adm_gray_900"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/bizStatLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/adm_gray_500"
        android:textSize="10.5sp" />
</LinearLayout>
