<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView style="@style/BizStepHeading" android:text="@string/biz_s4_title" />
    <TextView style="@style/BizStepSub" android:text="@string/biz_s4_sub" />

    <!-- Date range -->
    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="@string/biz_date_range" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btnOpenFrom"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_biz_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_calendar"
                app:tint="@color/adm_gray_400" />

            <TextView
                android:id="@+id/tvOpenFrom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/biz_open_from"
                android:textColor="@color/adm_gray_400"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnOpenUntil"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_biz_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_calendar"
                app:tint="@color/adm_gray_400" />

            <TextView
                android:id="@+id/tvOpenUntil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/biz_open_until"
                android:textColor="@color/adm_gray_400"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Mini calendar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_outline_gray_14"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/btnPrevMonth"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_adm_circle"
                android:backgroundTint="@color/adm_gray_100"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_left_24"
                    app:tint="@color/adm_gray_900" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvMonthTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/biz_calendar_month"
                android:textColor="@color/adm_gray_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/btnNextMonth"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_adm_circle"
                android:backgroundTint="@color/adm_gray_100"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right_24"
                    app:tint="@color/adm_gray_900" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bizMiniWeekdays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal" />

        <LinearLayout
            android:id="@+id/bizMiniGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/bizMiniLegend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal" />
    </LinearLayout>

    <!-- Block additional dates -->
    <LinearLayout
        android:id="@+id/btnBlockDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_image_picker"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_plus"
            app:tint="@color/adm_gray_600" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/biz_block_additional"
            android:textColor="@color/adm_gray_600"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
