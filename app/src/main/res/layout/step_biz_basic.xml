<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView style="@style/BizStepHeading" android:text="@string/biz_s1_title" />
    <TextView style="@style/BizStepSub" android:text="@string/biz_s1_sub" />

    <!-- Category -->
    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="@string/biz_category" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/bizCatHotel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/bizCatHotelIconWrap"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_adm_rounded_8">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_building"
                    app:tint="@color/adm_amber_500" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/biz_kind_hotel"
                    android:textColor="@color/adm_gray_900"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/biz_kind_hotel_sub"
                    android:textColor="@color/adm_gray_400"
                    android:textSize="10.5sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bizCatTour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/bizCatTourIconWrap"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_adm_rounded_8">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_map"
                    app:tint="@color/adm_teal_500" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/biz_kind_tour"
                    android:textColor="@color/adm_gray_900"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/biz_kind_tour_sub"
                    android:textColor="@color/adm_gray_400"
                    android:textSize="10.5sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Listing name -->
    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="@string/biz_listing_name" />

    <EditText
        style="@style/BizInput"
        android:id="@+id/bizName"
        android:hint="@string/biz_listing_name_hint"
        android:importantForAutofill="no"
        android:inputType="text" />

    <!-- Description -->
    <TextView style="@style/BizFieldLabel" android:layout_marginTop="14dp" android:text="@string/biz_description" />

    <EditText
        android:id="@+id/bizDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_biz_input"
        android:gravity="top"
        android:hint="@string/biz_description_hint"
        android:importantForAutofill="no"
        android:inputType="textMultiLine"
        android:minLines="3"
        android:padding="14dp"
        android:textColor="@color/adm_gray_900"
        android:textColorHint="@color/adm_gray_400"
        android:textSize="13sp" />

    <!-- Photos -->
    <TextView
        android:id="@+id/bizPhotosLabel"
        style="@style/BizFieldLabel"
        android:layout_marginTop="14dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/bizListingPhotoPreview"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/hotel_1"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Biz.Corner10" />

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/hotel_2"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Biz.Corner10" />

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/hotel_3"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Biz.Corner10" />

        <LinearLayout
            android:id="@+id/bizPhotoUpload"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginStart="3dp"
            android:layout_weight="1"
            android:background="@drawable/bg_image_picker"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_upload"
                app:tint="@color/adm_gray_500" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/biz_upload"
                android:textColor="@color/adm_gray_500"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
