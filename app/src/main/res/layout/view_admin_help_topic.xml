<?xml version="1.0" encoding="utf-8"?>
<!-- Help-center topic tile content (blue icon + label + article count).
     Included 4× by screen_admin_help.xml; AdminDetailActivity sets each one's
     icon / label / count via a scoped findViewById on the include's id. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_adm_rounded_8"
        android:backgroundTint="@color/adm_blue_50">

        <ImageView
            android:id="@+id/admTopicIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_gavel"
            app:tint="@color/adm_blue_500" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/admTopicLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/adm_gray_900"
            android:textSize="12.5sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/admTopicCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/adm_gray_400"
            android:textSize="10.5sp" />
    </LinearLayout>
</LinearLayout>
