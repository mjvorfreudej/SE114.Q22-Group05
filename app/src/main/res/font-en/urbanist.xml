<?xml version="1.0" encoding="utf-8"?>
<!--
    App text family — ENGLISH ("en") override of @font/urbanist.

    English ships only Latin text, so it uses the real Urbanist .ttf set (full
    400/500/600/700 weight range). Vietnamese (the default locale) uses Be Vietnam
    Pro instead — see res/font/urbanist.xml — because Urbanist lacks Vietnamese glyphs.
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        android:font="@font/urbanist_regular"
        android:fontWeight="400"
        android:fontStyle="normal"
        app:font="@font/urbanist_regular"
        app:fontWeight="400"
        app:fontStyle="normal" />
    <font
        android:font="@font/urbanist_medium"
        android:fontWeight="500"
        android:fontStyle="normal"
        app:font="@font/urbanist_medium"
        app:fontWeight="500"
        app:fontStyle="normal" />
    <font
        android:font="@font/urbanist_semibold"
        android:fontWeight="600"
        android:fontStyle="normal"
        app:font="@font/urbanist_semibold"
        app:fontWeight="600"
        app:fontStyle="normal" />
    <font
        android:font="@font/urbanist_bold"
        android:fontWeight="700"
        android:fontStyle="normal"
        app:font="@font/urbanist_bold"
        app:fontWeight="700"
        app:fontStyle="normal" />
</font-family>
