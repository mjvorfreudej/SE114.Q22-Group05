<?xml version="1.0" encoding="utf-8"?>
<!--
    English (and other Latin-only locales) Urbanist family.

    These .ttf files carry the full weight range (400/500/600/700) but NOT the
    Vietnamese precomposed glyphs, so they are scoped to the "en" resource
    qualifier. Vietnamese (the default locale) uses res/font/urbanist.xml, which
    is built from the *_vn.otf subset that does contain the Vietnamese glyphs.
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        android:font="@font/urbanist_regular"
        android:fontWeight="400"
        android:fontStyle="normal"
        app:font="@font/urbanist_regular"
        app:fontWeight="400"
        app:fontStyle="normal" />
    <font
        android:font="@font/urbanist_medium"
        android:fontWeight="500"
        android:fontStyle="normal"
        app:font="@font/urbanist_medium"
        app:fontWeight="500"
        app:fontStyle="normal" />
    <font
        android:font="@font/urbanist_semibold"
        android:fontWeight="600"
        android:fontStyle="normal"
        app:font="@font/urbanist_semibold"
        app:fontWeight="600"
        app:fontStyle="normal" />
    <font
        android:font="@font/urbanist_bold"
        android:fontWeight="700"
        android:fontStyle="normal"
        app:font="@font/urbanist_bold"
        app:fontWeight="700"
        app:fontStyle="normal" />
</font-family>
